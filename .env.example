NODE_ENV=<Your node environment here, e.g., development or production>

# Better Auth configuration
BETTER_AUTH_SECRET=<Your auth secret here, generated here https://www.better-auth.com/docs/installation>
BETTER_AUTH_URL=<Base URL of your app>

# Auth mode: oauth (Pretix/OAuth) or credentials (email/password). Defaults to oauth.
AUTH_MODE=oauth

# Turnstile configuration
TURNSTILE_SITE_KEY=<Your Turnstile site key here>
TURNSTILE_SECRET_KEY=<Your Turnstile secret key here>

# OAuth configuration (required only when AUTH_MODE=oauth)
OAUTH_PROVIDER_NAME=<Your human-readable OAuth provider name here, e.g., Pretix>
OAUTH_PROVIDER_ID=<Your OAuth provider ID here>
OAUTH_DISCOVERY_URL=<Your OAuth provider discovery URL here>
OAUTH_CLIENT_ID=<Your OAuth client ID here>
OAUTH_CLIENT_SECRET=<Your OAuth client secret here>

# Postgres configuration
# Full connection string (use for Neon; overrides individual vars below)
POSTGRES_URL=<postgresql://user:password@host/dbname?sslmode=require>
POSTGRES_HOST=<Your Postgres host here>
POSTGRES_USER=<Your Postgres username here>
POSTGRES_PASSWORD=<Your Postgres password here>
POSTGRES_DB=<Your Postgres database name here>
POSTGRES_SCHEMA=<Your Postgres schema name here>
POSTGRES_PORT=<Your Postgres port here, default is 5432>

# SMTP (for password reset / verification emails when AUTH_MODE=credentials)
# If unset, reset links are logged to the server console in development.
SMTP_HOST=<e.g. smtp.example.com>
SMTP_PORT=<e.g. 587>
SMTP_SECURE=<true if port 465, otherwise false>
SMTP_USER=<SMTP username>
SMTP_PASSWORD=<SMTP password>
SMTP_FROM=<Sender address, e.g. noreply@example.com>

# Application configuration
APP_NAME=<Your application name here. ie, volunteer-next>
RESET_PASSWORD_TOKEN_EXPIRES_IN=<e.g. 15*60 for 15 minutes>
LOCKOUT_THRESHOLD=<Number of failed login attempts before locking out>
LOCKOUT_DURATION_MS=<Duration of lockout in milliseconds>
PRUNE_INTERVAL_MS=<Interval at which to prune expired lockouts in milliseconds>
RESET_PASSWORD_WINDOW_MS=<Window size for counting reset password attempts in milliseconds>
RESET_PASSWORD_MAX_ATTEMPTS=<Maximum number of reset password attempts within the time window>
SIGNUP_WINDOW_MS=<Window size for counting signup attempts in milliseconds>
SIGNUP_MAX_ATTEMPTS=<Maximum number of signup attempts within the time window>
USE_EMAIL_QUEUE=<Whether to use the email queue for sending emails (true/false)>

# Debugging flags
DEFAULT_THEME=<Default theme to use: system | light | dark>
DEBUG_FORCE_ROLE=<Role to force for debugging purposes: admin, organiser, team-lead>
DEBUG_FORCE_ROLE_EVENTID=<Event ID to use when forcing a role that requires an event ID>
DEBUG_FORCE_ROLE_TEAMID=<Team ID to use when forcing a role that requires a team ID>